
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      // Check if the requesting user is the owner of the document.
      return request.auth.uid == resource.data[ownerId];
    }
    
    function isOwnerCreate(ownerId) {
        // Check if the user is creating a document for themselves.
        return request.auth.uid == request.resource.data[ownerId];
    }

    function idStartsWithUid(docId) {
        // Check if a document ID starts with the user's UID.
        return docId.startsWith(request.auth.uid);
    }
    
    function isAdmin() {
        // Check if the user has an ADMIN role in their user document.
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function ownerUnchanged(ownerId) {
        // Ensure the ownerId field is not changed during an update.
        return request.resource.data[ownerId] == resource.data[ownerId];
    }

    // --- COLLECTIONS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if request.resource.data.role == 'USER';
      allow update: if isAdmin() || (request.auth.uid == userId);
    }

    match /customers/{customerId} {
      allow get: if isAdmin() || isOwner('ownerId');
      allow list: if isSignedIn();
      allow create: if isAdmin() || isOwnerCreate('ownerId');
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin() || isOwner('ownerId');
    }

    match /products/{productId} {
      allow read: if isAdmin() || isOwner('ownerId'); 
      allow create: if isAdmin() || isOwnerCreate('ownerId');
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin() || isOwner('ownerId');
    }

    match /invoices/{invoiceId} {
      allow get: if isAdmin() || idStartsWithUid(invoiceId);
      allow list: if isSignedIn();
      allow create: if isAdmin() || (idStartsWithUid(invoiceId) && isOwnerCreate('ownerId'));
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin();
    }

    match /day_products/{dayProductId} {
      allow read: if isAdmin() || isOwner('ownerId');
      allow create: if isAdmin() || (idStartsWithUid(dayProductId) && isOwnerCreate('ownerId'));
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin();
    }

    match /consumption_records/{recordId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() || isOwnerCreate('ownerId');
      allow update, delete: if isAdmin() || isOwner('ownerId');
    }

    match /payments/{paymentId} {
        allow get, list: if isSignedIn();
        allow create: if isAdmin() || isOwnerCreate('ownerId');
        allow update, delete: if false;
    }
  }
}
