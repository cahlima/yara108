
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check for admin
    function isAdmin() {
      // This function requires the /admins/{adminId} rule below to work
      return request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists;
    }

    // ADMINS: Allow users to read their own admin status. Allow other admins to write.
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow write: if isAdmin();
    }

    // PRODUCTS: Allow any authenticated user to list/get products, only admins can write
    match /products/{productId} {
      allow get, list: if request.auth != null; // CORRECTED RULE
      allow write: if isAdmin();
    }

    // CUSTOMERS: This collection might be phased out, but keeping rules for safety.
    match /customers/{customerId} {
      allow get, list: if request.auth != null; // CORRECTED RULE
      allow write: if isAdmin();
    }

    // DAY_PRODUCTS: Users can only manage their own day_products
    match /day_products/{dayProductId} {
      allow list: if isOwner(request.query.user_id);
      allow get: if isOwner(resource.data.user_id);
      allow create: if isOwner(request.resource.data.user_id);
      allow update, delete: if isOwner(resource.data.user_id);
    }

    // CONSUMPTION_RECORDS: Users can only manage their own consumption records
    match /consumption_records/{recordId} {
      allow list: if isOwner(request.query.user_id);
      allow get: if isOwner(resource.data.user_id);
      allow create: if isOwner(request.resource.data.user_id);
      allow update, delete: if isOwner(resource.data.user_id);
    }
    
    // USERS: Treated as the customer list.
    match /users/{userId} {
      // Admins can read and write the entire collection.
      allow read, write: if isAdmin();
      // Individual users can get their own document.
      allow get: if isOwner(userId);
    }
  }
}
