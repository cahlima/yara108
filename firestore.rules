
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerIdField) {
      // Check if the requesting user is the owner of the document.
      return request.auth.uid == resource.data[ownerIdField];
    }
    
    function isOwnerCreate(ownerIdField) {
      // Check if the user is creating a document for themselves.
      return request.auth.uid == request.resource.data[ownerIdField];
    }

    function idStartsWithUid(docId) {
      // Check if a document ID starts with the user's UID by splitting the string.
      // Used for documents where the ID format is `uid_...`
      return docId.split('_')[0] == request.auth.uid;
    }
    
    function isAdmin() {
      // Check if the user has an admin custom claim.
      return request.auth.token.admin == true;
    }

    function ownerUnchanged(ownerIdField) {
      // Ensure the ownerId field is not changed during an update.
      // Allow the write if the ownerIdField is not in the request data (not being changed)
      // or if it is in the request data but the value is the same.
      return !(ownerIdField in request.resource.data) || request.resource.data[ownerIdField] == resource.data[ownerIdField];
    }

    // --- COLLECTIONS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create; // Allow any user to create their own user document
      allow update: if isAdmin() || request.auth.uid == userId;
    }

    // Products and Customers are public to any logged-in user
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if isOwnerCreate('ownerId');
      allow update: if isOwner('ownerId') && ownerUnchanged('ownerId');
      allow delete: if isOwner('ownerId');
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isOwnerCreate('ownerId');
      allow update: if isOwner('ownerId') && ownerUnchanged('ownerId');
      allow delete: if isOwner('ownerId');
    }

    // Invoices are private, readable by owner (via ID) or admin
    match /invoices/{invoiceId} {
      // ID Format: ownerId_customerId_month
      allow read: if isAdmin() || idStartsWithUid(invoiceId);
      allow create: if idStartsWithUid(invoiceId) && isOwnerCreate('ownerId');
      allow update: if (isAdmin() || idStartsWithUid(invoiceId)) && ownerUnchanged('ownerId');
      allow delete: if isAdmin();
    }

    // Day Products are private, readable by owner (via ID) or admin
    match /day_products/{dayProductId} {
      // ID Format: ownerId_dayId
      allow read: if isAdmin() || idStartsWithUid(dayProductId);
      allow create: if idStartsWithUid(dayProductId) && isOwnerCreate('ownerId');
      allow update: if (isAdmin() || idStartsWithUid(dayProductId)) && ownerUnchanged('ownerId');
      allow delete: if isAdmin();
    }

    // Consumption records are private to their owner or admin
    match /consumption_records/{recordId} {
      allow read, delete: if isAdmin() || isOwner('ownerId');
      allow create: if isOwnerCreate('ownerId');
      allow update: if false; // Should not be updated, only created/deleted
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || isOwner('ownerId');
      allow create: if isOwnerCreate('ownerId');
      allow update, delete: if false;
    }
  }
}
