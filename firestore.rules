rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerIdField) {
      return request.auth.uid == resource.data[ownerIdField];
    }
    
    function isOwnerCreate(ownerIdField) {
      return request.auth.uid == request.resource.data[ownerIdField];
    }

    function idStartsWithUid(docId) {
      return docId.split('_')[0] == request.auth.uid;
    }
    
    function isAdmin() {
      return request.auth.token.admin == true;
    }

    function ownerUnchanged(ownerIdField) {
      return !(ownerIdField in request.resource.data) || request.resource.data[ownerIdField] == resource.data[ownerIdField];
    }

    // --- COLLECTIONS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create;
      allow update: if isAdmin() || request.auth.uid == userId;
    }

    match /customers/{customerId} {
      // CORREÇÃO: Apenas admins podem listar todos os clientes.
      allow get: if isSignedIn();
      allow list: if isAdmin(); 
      allow create: if isOwnerCreate('ownerId');
      allow update: if isOwner('ownerId') && ownerUnchanged('ownerId');
      allow delete: if isOwner('ownerId');
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isOwnerCreate('ownerId');
      allow update: if isOwner('ownerId') && ownerUnchanged('ownerId');
      allow delete: if isOwner('ownerId');
    }

    match /invoices/{invoiceId} {
      allow read: if isAdmin() || idStartsWithUid(invoiceId);
      allow create: if idStartsWithUid(invoiceId) && isOwnerCreate('ownerId');
      allow update: if (isAdmin() || idStartsWithUid(invoiceId)) && ownerUnchanged('ownerId');
      allow delete: if isAdmin() || isOwner('ownerId');
    }

    match /day_products/{dayProductId} {
      allow read: if isAdmin() || idStartsWithUid(dayProductId);
      allow create: if idStartsWithUid(dayProductId) && isOwnerCreate('ownerId');
      allow update: if isAdmin() || idStartsWithUid(dayProductId);
      allow delete: if isAdmin() || idStartsWithUid(dayProductId);
    }

    match /consumption_records/{recordId} {
      // CORREÇÃO: Admins podem listar todos os registros para encontrar débitos.
      allow get: if isOwner('ownerId');
      allow list: if isAdmin();
      allow create: if isOwnerCreate('ownerId') || isOwner('ownerId');
      allow delete: if isAdmin() || isOwner('ownerId');
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId') &&
                    (isAdmin() || request.resource.data.diff(resource.data).changedKeys().hasOnly(['date', 'invoiceId']));
    }

    // ADICIONADO: Regras para a coleção 'payments' usada no Relatório Diário.
    match /payments/{paymentId} {
        allow read: if isAdmin() || isOwner('ownerId');
        allow create: if isOwnerCreate('ownerId');
        allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
        allow delete: if isAdmin();
    }

    match /payment_records/{recordId} {
      allow read: if isAdmin() || isOwner('ownerId');
      allow create: if isOwnerCreate('ownerId');
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin();
    }
  }
}
