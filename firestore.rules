rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }

    function isOwner(fieldName) {
      return isSignedIn()
        && resource != null
        && resource.data[fieldName] == request.auth.uid;
    }

    function isOwnerCreate(fieldName) {
      return isSignedIn()
        && request.resource.data[fieldName] == request.auth.uid;
    }

    function ownerUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    function idStartsWithUid(docId) {
      return isSignedIn() && docId.matches('^' + request.auth.uid + '_.*$');
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }

    match /customers/{id} {
      allow get, list: if isAdmin() || isOwner('ownerId');
      allow create: if isAdmin() || isOwnerCreate('ownerId');
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin() || isOwner('ownerId');
    }

    match /products/{id} {
      allow get, list: if isAdmin() || isOwner('ownerId');
      allow create: if isAdmin() || isOwnerCreate('ownerId');
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin() || isOwner('ownerId');
    }

    match /invoices/{invoiceId} {
      // transação precisa de get mesmo quando doc não existe
      allow get: if isAdmin() || idStartsWithUid(invoiceId) || isOwner('ownerId');

      // list/query só passa se a query for compatível com ownerId==uid (regras não filtram)
      allow list: if isAdmin() || isOwner('ownerId');

      allow create: if isAdmin() || (idStartsWithUid(invoiceId) && isOwnerCreate('ownerId'));
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin();
    }

    match /day_products/{dayProductId} {
      allow get: if isAdmin() || idStartsWithUid(dayProductId) || isOwner('ownerId');
      allow list: if isAdmin() || isOwner('ownerId');
      allow create: if isAdmin() || (idStartsWithUid(dayProductId) && isOwnerCreate('ownerId'));
      allow update: if (isAdmin() || isOwner('ownerId')) && ownerUnchanged('ownerId');
      allow delete: if isAdmin();
    }

    match /consumption_records/{recordId} {
      allow get, list: if isAdmin() || isOwner('ownerId');
      allow create: if isAdmin() || isOwnerCreate('ownerId');
      allow update, delete: if false;
    }
  }
}
