rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin status (non-recursive)
    // NOTE: This now relies on a custom claim for definitive admin checks.
    // The rule on /admins collection is used for the frontend's initial check.
    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // ADMINS: Temporary fix to allow frontend to check admin status without "client offline" error.
    match /admins/{adminId} {
      // Allow any authenticated user to read. The frontend checks if the doc exists.
      allow get: if request.auth != null;
      // Temporarily disable write access to prevent issues. Definitive solution uses custom claims.
      allow write: if false; 
    }

    // PRODUCTS: Allow any authenticated user to list/get products, only admins can write
    match /products/{productId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }

    // CUSTOMERS: Phased out, but keeping rules for safety.
    match /customers/{customerId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }

    // Restore original secure rules, as the issue was not here.
    match /day_products/{dayProductId} {
      allow read, write: if request.auth != null;
    }

    match /consumption_records/{recordId} {
      allow read, write: if request.auth != null;
    }
    
    // USERS: Treated as the customer list.
    match /users/{userId} {
      allow read, write: if isAdmin();
      allow get: if request.auth.uid == userId;
    }
  }
}
